<% content_for :title, "#{@episode.display_name} — Full Transcript | FindThePhrase" %>
<% content_for :description, "The complete transcript for Little Bear episode #{@episode.display_name}, indexed and quietly typeset for parents and readers." %>
<% content_for :head do %>
  <meta property="og:title" content="<%= @episode.display_name %> — Little Bear">
  <meta property="og:description" content="The complete transcript for Little Bear episode <%= @episode.display_name %>.">
  <meta property="og:type" content="article">
  <meta name="twitter:card" content="summary">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TVEpisode",
    "name": "<%= @episode.display_name %>",
    "episodeNumber": "<%= @episode.episode_number %>",
    "seasonNumber": "<%= @episode.season %>",
    "partOfSeries": { "@type": "TVSeries", "name": "Little Bear" },
    "transcript": "<%= @transcript_segments.map(&:text).join(' ') %>"
  }
  </script>
<% end %>

<%= render "shared/header", subtitle: "Reading room" %>

<main class="max-w-5xl mx-auto px-5 sm:px-8 lg:px-12">

  <%# Breadcrumb — folio mark %>
  <nav class="pt-8 pb-4">
    <%= link_to root_path, class: "inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint hover:text-vermilion transition-colors" do %>
      <svg class="w-3 h-3" viewBox="0 0 12 12" fill="none">
        <path d="M10 6 H 2 M 5 3 L 2 6 L 5 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Back to the index
    <% end %>
  </nav>

  <%# Chapter title page %>
  <header class="pt-6 pb-12">
    <p class="ink-rise font-mono text-[11px] tracking-[0.22em] uppercase text-vermilion mb-3">
      Season <%= @episode.season %> &nbsp;·&nbsp; Episode <%= @episode.episode_number %>
    </p>
    <h1 class="ink-rise ink-rise-delay-1 font-display text-5xl sm:text-7xl text-ink leading-[0.95] tracking-[-0.03em]">
      <%= @episode.display_name %>
    </h1>
    <p class="ink-rise ink-rise-delay-2 mt-5 font-body-italic text-lg text-ink-soft">
      <%= pluralize(@transcript_segments.count, 'line') %> of dialogue, transcribed in order.
    </p>

    <%# Hand-drawn ornament under chapter heading %>
    <svg width="120" height="18" viewBox="0 0 120 18" fill="none" class="mt-8 ink-rise ink-rise-delay-3" aria-hidden="true">
      <path d="M2 9 Q 20 1, 40 9 T 80 9 T 118 9" stroke="#c84b31" stroke-width="1.4" fill="none" stroke-linecap="round"/>
      <circle cx="60" cy="9" r="2" fill="#c84b31"/>
    </svg>
  </header>

  <%# Transcript reading column %>
  <article class="pb-16"<% if @target_segment_id %> data-controller="scroll-to-segment" data-scroll-to-segment-segment-id-value="<%= @target_segment_id %>"<% end %>>
    <% @transcript_segments.each_with_index do |segment, idx| %>
      <% is_target = @target_segment_id && @target_segment_id.to_i == segment.position %>
      <div id="segment-<%= segment.position %>"
           class="grid grid-cols-12 gap-x-4 sm:gap-x-8 py-2 group <%= 'bg-honey-soft/40 -mx-3 px-3 sm:-mx-6 sm:px-6 rounded-md' if is_target %>">
        <%# Marginalia: timestamp every ~5 segments or on target %>
        <div class="col-span-2 sm:col-span-2 pt-2">
          <% if idx == 0 || idx % 5 == 0 || is_target %>
            <span class="marginalia"><%= format_timestamp(segment.timestamp_from) %></span>
          <% end %>
        </div>

        <div class="col-span-10 sm:col-span-9">
          <p class="<%= idx == 0 ? 'drop-cap' : '' %> font-display-text text-[1.18rem] sm:text-[1.32rem] leading-relaxed text-ink">
            <%= segment.text %>
          </p>
        </div>

        <%# Right margin: small favorite affordance on hover %>
        <div class="col-span-12 sm:col-span-1 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity flex sm:justify-end pt-2">
          <% if segment.favorited? %>
            <%= form_with url: favorite_segment_path(segment.id), method: :delete, local: true, class: "inline-block" do |form| %>
              <%= form.button type: :submit, class: "p-1 text-vermilion", title: "Remove favorite" do %>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 20.5s-7.5-4.6-9.3-9.3C1.5 7.7 4 4.5 7.4 4.5c1.9 0 3.6 1 4.6 2.6 1-1.6 2.7-2.6 4.6-2.6 3.4 0 5.9 3.2 4.7 6.7C19.5 15.9 12 20.5 12 20.5z"/>
                </svg>
              <% end %>
            <% end %>
          <% else %>
            <%= form_with url: favorite_segments_path, method: :post, local: true, class: "inline-block" do |form| %>
              <%= form.hidden_field :transcript_segment_id, value: segment.id %>
              <%= form.button type: :submit, class: "p-1 text-ink-faint hover:text-vermilion transition-colors", title: "Save line" do %>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.5s-7.5-4.6-9.3-9.3C1.5 7.7 4 4.5 7.4 4.5c1.9 0 3.6 1 4.6 2.6 1-1.6 2.7-2.6 4.6-2.6 3.4 0 5.9 3.2 4.7 6.7C19.5 15.9 12 20.5 12 20.5z"/>
                </svg>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </article>

  <%# End-of-chapter ornament %>
  <div class="flex flex-col items-center pb-16">
    <svg width="180" height="20" viewBox="0 0 180 20" fill="none" aria-hidden="true">
      <path d="M2 10 Q 30 2, 60 10 T 118 10 T 178 10" stroke="#c84b31" stroke-width="1.4" fill="none" stroke-linecap="round"/>
      <circle cx="90" cy="10" r="2.5" fill="#c84b31"/>
    </svg>
    <%= link_to root_path, class: "mt-8 inline-flex items-center gap-2 px-6 py-3 bg-ink text-paper hover:bg-vermilion-deep font-display-text text-sm tracking-wide rounded-full transition-colors" do %>
      <svg class="w-3.5 h-3.5" viewBox="0 0 12 12" fill="none">
        <path d="M10 6 H 2 M 5 3 L 2 6 L 5 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Return to the index
    <% end %>
  </div>
</main>

<%= render "shared/footer" %>

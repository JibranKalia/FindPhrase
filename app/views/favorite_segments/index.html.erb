<% content_for :title, "Favorites — FindThePhrase" %>

<%= render "shared/header", subtitle: "A commonplace book" %>

<main class="max-w-5xl mx-auto px-5 sm:px-8 lg:px-12">

  <%# Title block %>
  <section class="pt-10 sm:pt-14 pb-10">
    <div class="grid grid-cols-12 gap-x-6 items-end">
      <div class="col-span-12 sm:col-span-9">
        <p class="ink-rise font-mono text-[11px] tracking-[0.22em] uppercase text-vermilion mb-4">
          Vol. II &nbsp;·&nbsp; Lines pressed between pages
        </p>
        <h1 class="ink-rise ink-rise-delay-1 font-display text-5xl sm:text-7xl text-ink leading-[0.95] tracking-[-0.03em]">
          <span class="font-body-italic font-light text-ink-soft">Your</span>
          favourite
          <span class="text-vermilion italic">passages.</span>
        </h1>
        <p class="ink-rise ink-rise-delay-2 mt-5 font-body-italic text-lg text-ink-soft max-w-xl">
          <%= pluralize(@favorite_segments.count, 'line') %> kept —
          a small anthology of moments your child loves to repeat.
        </p>
      </div>

      <div class="hidden sm:flex col-span-3 justify-end ink-rise ink-rise-delay-3">
        <svg viewBox="0 0 100 100" class="w-24 h-24 drift" fill="none" aria-hidden="true">
          <%# Pressed-flower illustration in vermilion ink %>
          <circle cx="50" cy="50" r="6" fill="#c84b31"/>
          <ellipse cx="50" cy="32" rx="6" ry="14" fill="#c84b31" opacity="0.85"/>
          <ellipse cx="68" cy="50" rx="14" ry="6" fill="#c84b31" opacity="0.85"/>
          <ellipse cx="50" cy="68" rx="6" ry="14" fill="#c84b31" opacity="0.85"/>
          <ellipse cx="32" cy="50" rx="14" ry="6" fill="#c84b31" opacity="0.85"/>
          <path d="M50 56 Q 48 75, 35 90" stroke="#5f6b3e" stroke-width="1.4" fill="none" stroke-linecap="round"/>
          <path d="M44 78 Q 38 76, 36 80" stroke="#5f6b3e" stroke-width="1.2" fill="none" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </section>

  <% if @favorite_segments.any? %>
    <%# Grouped by episode — chapter style %>
    <div class="space-y-14 pb-16">
      <% @grouped_favorites.each_with_index do |(episode, favorites), idx| %>
        <article>
          <header class="flex items-end justify-between border-b border-ink/30 pb-3">
            <div class="flex items-baseline gap-4">
              <span class="font-mono text-xs text-ink-faint tracking-[0.18em] uppercase">
                Folio <%= sprintf("%02d", idx + 1) %>
              </span>
              <%= link_to episode_path(episode.episode_id),
                  class: "font-display text-3xl sm:text-4xl text-ink hover:text-vermilion transition-colors leading-none" do %>
                <%= episode.display_name %>
              <% end %>
            </div>
            <span class="font-mono text-xs text-ink-faint hidden sm:inline">
              <%= pluralize(favorites.count, 'line') %>
            </span>
          </header>
          <div class="border-b border-paper-edge mb-2"></div>

          <ul>
            <% favorites.each do |favorite| %>
              <% segment = favorite.transcript_segment %>
              <li class="border-b border-paper-edge/60 last:border-b-0">
                <%= link_to episode_path(episode.episode_id, segment: segment.position),
                    class: "block py-7 sm:py-8 group hover:bg-paper-deep/30 transition-colors -mx-3 sm:-mx-5 px-3 sm:px-5 rounded-md",
                    data: { turbo_frame: "_top" } do %>
                  <div class="grid grid-cols-12 gap-x-4 sm:gap-x-6">
                    <%# Marginalia: timestamp + saved date %>
                    <div class="col-span-3 sm:col-span-2 pt-1">
                      <span class="marginalia block">
                        <%= format_timestamp(segment.timestamp_from) %>
                      </span>
                      <span class="block mt-2 font-body-italic text-[11px] text-ink-faint">
                        kept <%= time_ago_in_words(favorite.created_at) %> ago
                      </span>
                    </div>

                    <%# Passage %>
                    <div class="col-span-9 sm:col-span-9">
                      <p class="font-display text-2xl sm:text-3xl leading-[1.15] text-ink">
                        <span class="text-vermilion font-display-text text-3xl sm:text-4xl leading-none align-[-0.15em]">"</span><%= segment.text %><span class="text-vermilion font-display-text text-3xl sm:text-4xl leading-none align-[-0.15em]">"</span>
                      </p>
                    </div>

                    <%# Right: unfavorite %>
                    <div class="col-span-12 sm:col-span-1 flex sm:justify-end items-start pt-1">
                      <%= form_with url: favorite_segment_path(segment.id), method: :delete, local: true, class: "inline-block" do |form| %>
                        <%= form.hidden_field :transcript_segment_id, value: segment.id %>
                        <%= form.button type: :submit,
                            onclick: "event.preventDefault(); event.stopPropagation(); this.closest('form').submit();",
                            class: "p-1.5 text-vermilion hover:text-vermilion-deep transition-colors",
                            title: "Remove from favorites" do %>
                          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 20.5s-7.5-4.6-9.3-9.3C1.5 7.7 4 4.5 7.4 4.5c1.9 0 3.6 1 4.6 2.6 1-1.6 2.7-2.6 4.6-2.6 3.4 0 5.9 3.2 4.7 6.7C19.5 15.9 12 20.5 12 20.5z"/>
                          </svg>
                        <% end %>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </li>
            <% end %>
          </ul>
        </article>
      <% end %>
    </div>

  <% else %>
    <%# Empty state — quiet, written in italic prose %>
    <section class="py-12 sm:py-20 max-w-2xl">
      <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-vermilion mb-4">An empty volume</p>
      <h2 class="font-display text-4xl sm:text-5xl text-ink leading-[0.95]">
        Nothing kept yet —
        <span class="italic text-ink-soft">but the index is open.</span>
      </h2>
      <p class="mt-6 text-lg text-ink-soft leading-relaxed">
        Search a phrase, and tap the <span class="inline-flex items-center align-middle text-vermilion">
          <svg class="w-4 h-4 mx-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.5s-7.5-4.6-9.3-9.3C1.5 7.7 4 4.5 7.4 4.5c1.9 0 3.6 1 4.6 2.6 1-1.6 2.7-2.6 4.6-2.6 3.4 0 5.9 3.2 4.7 6.7C19.5 15.9 12 20.5 12 20.5z"/>
          </svg>
        </span> beside any line.
        It will live here, ready when your child asks for it again.
      </p>

      <%= link_to root_path, class: "mt-10 inline-flex items-center gap-2 px-6 py-3 bg-ink text-paper hover:bg-vermilion-deep font-display-text text-sm tracking-wide rounded-full transition-colors" do %>
        <span>Open the index</span>
        <svg class="w-3.5 h-3.5" viewBox="0 0 12 12" fill="none">
          <path d="M2 6 H 10 M 7 3 L 10 6 L 7 9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      <% end %>
    </section>
  <% end %>
</main>

<%= render "shared/footer" %>

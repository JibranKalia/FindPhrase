<% content_for :title, "FindThePhrase — A Reader's Index of Little Bear" %>

<%= render "shared/header" %>

<main class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-12">

  <%# ─────────── HERO + SEARCH (compact, search above the fold) ─────────── %>
  <% if @query.blank? %>
    <section class="pt-6 sm:pt-8 pb-10">
      <div class="grid grid-cols-12 gap-x-6 items-center">
        <div class="col-span-12 sm:col-span-9 lg:col-span-10">
          <p class="ink-rise font-mono text-[10px] tracking-[0.22em] uppercase text-vermilion mb-2">
            Vol. I &nbsp;·&nbsp; <%= Episode.count %> episodes &nbsp;·&nbsp; Indexed for parents
          </p>
          <h1 class="ink-rise ink-rise-delay-1 font-display tracking-[-0.03em] leading-[0.95] text-3xl sm:text-4xl lg:text-5xl text-ink">
            Find the
            <span class="italic text-vermilion">phrase</span>
            your child remembers.
          </h1>
          <p class="ink-rise ink-rise-delay-2 mt-2 max-w-2xl text-base text-ink-soft leading-snug">
            Every episode of <em>Little Bear</em>, transcribed and indexed — so a half-heard line finds its scene.
          </p>
        </div>

        <div class="hidden sm:flex col-span-3 lg:col-span-2 justify-end ink-rise ink-rise-delay-3">
          <%# Compact bear glyph %>
          <svg viewBox="0 0 100 100" class="w-16 h-16 lg:w-20 lg:h-20" fill="none" aria-hidden="true">
            <ellipse cx="50" cy="58" rx="28" ry="26" fill="#c84b31"/>
            <circle cx="32" cy="34" r="9" fill="#c84b31"/>
            <circle cx="68" cy="34" r="9" fill="#c84b31"/>
            <circle cx="32" cy="34" r="4" fill="#1f1a14"/>
            <circle cx="68" cy="34" r="4" fill="#1f1a14"/>
            <circle cx="42" cy="52" r="2.4" fill="#1f1a14"/>
            <circle cx="58" cy="52" r="2.4" fill="#1f1a14"/>
            <ellipse cx="50" cy="62" rx="3.6" ry="2.6" fill="#1f1a14"/>
            <path d="M50 64 V 70 M 46 70 Q 50 73, 54 70" stroke="#1f1a14" stroke-width="1.4" stroke-linecap="round" fill="none"/>
          </svg>
        </div>
      </div>

      <%# ─────────── SEARCH FIELD ─────────── %>
      <div class="ink-rise ink-rise-delay-4 mt-6">
        <%= render "search_form", query: @query %>
      </div>

      <%# ─────────── POPULAR PHRASES ─────────── %>
      <div class="ink-rise ink-rise-delay-5 mt-10">
        <div class="flex items-baseline gap-3 mb-4">
          <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-vermilion">№1</span>
          <h2 class="font-display text-xl sm:text-2xl text-ink">Phrases parents look up most</h2>
        </div>

        <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-1.5">
          <% search_suggestions.each_with_index do |phrase, i| %>
            <li class="flex items-baseline gap-3 border-t border-paper-edge/70 pt-2 group">
              <span class="font-mono text-[10px] text-ink-faint w-5 shrink-0"><%= sprintf("%02d", i + 1) %></span>
              <%= link_to search_path(query: phrase),
                  class: "flex-1 font-display text-base sm:text-lg text-ink hover:text-vermilion transition-colors",
                  data: { turbo: false } do %>
                <span class="italic">"<%= phrase %>"</span>
              <% end %>
              <svg class="w-3 h-3 text-ink-faint group-hover:text-vermilion shrink-0 mt-1 transition-all group-hover:translate-x-1" viewBox="0 0 12 12" fill="none">
                <path d="M2 6 H 10 M 7 3 L 10 6 L 7 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </li>
          <% end %>
        </ul>
      </div>
    </section>

  <% else %>
    <%# ─────────── RESULTS LAYOUT ─────────── %>
    <section class="pt-10 sm:pt-12 pb-12">
      <%= render "search_form", query: @query %>
    </section>

    <%= turbo_frame_tag "search_results" do %>
      <% if @results.any? %>
        <div class="mb-10 flex items-baseline justify-between gap-4 flex-wrap">
          <p class="font-display text-2xl sm:text-3xl text-ink leading-snug">
            <span class="font-body-italic text-ink-soft">Found</span>
            <span class="text-vermilion"><%= @total_matches %></span>
            <span class="font-body-italic text-ink-soft">passages of</span>
            "<span class="italic"><%= @query %></span>"
            <span class="font-body-italic text-ink-soft">across</span>
            <%= @grouped_results.keys.count %>
            <span class="font-body-italic text-ink-soft">episode<%= 's' if @grouped_results.keys.count != 1 %>.</span>
          </p>
        </div>

        <div class="space-y-12 sm:space-y-16">
          <% @grouped_results.each_with_index do |(episode, results), idx| %>
            <article>
              <%# Chapter header — folio style %>
              <header class="flex items-end justify-between gap-4 border-b border-ink/30 pb-3 mb-1">
                <div class="flex items-baseline gap-4 flex-wrap min-w-0">
                  <span class="font-mono text-xs text-ink-faint tracking-[0.18em] uppercase whitespace-nowrap">
                    Ch. <%= sprintf("%02d", idx + 1) %> &nbsp;·&nbsp; <%= episode.episode_id %>
                  </span>
                  <h2 class="font-display text-2xl sm:text-3xl text-ink leading-tight">
                    <%= episode.display_name %>
                  </h2>
                </div>
                <span class="font-mono text-xs text-ink-faint hidden sm:inline whitespace-nowrap">
                  <%= results.count %> <%= results.count == 1 ? 'match' : 'matches' %>
                </span>
              </header>
              <div class="border-b border-paper-edge mb-2"></div>

              <ul>
                <% results.each do |result| %>
                  <%= render 'result_card', result: result %>
                <% end %>
              </ul>
            </article>
          <% end %>
        </div>

      <% else %>
        <%# ─────────── NO RESULTS ─────────── %>
        <div class="py-16 sm:py-24 max-w-2xl">
          <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-vermilion mb-4">Nothing in the index</p>
          <h2 class="font-display text-4xl sm:text-5xl text-ink leading-[0.95]">
            We couldn't find <span class="italic">"<%= @query %>"</span>
            <span class="text-ink-soft">in any episode.</span>
          </h2>
          <p class="mt-6 text-lg text-ink-soft leading-relaxed">
            Try a slightly different spelling, or one of these well-loved lines —
            children rephrase as they go.
          </p>

          <ul class="mt-8 space-y-3">
            <% search_suggestions.take(5).each_with_index do |phrase, i| %>
              <li class="flex items-baseline gap-4 border-t border-paper-edge pt-3">
                <span class="font-mono text-xs text-ink-faint w-6"><%= sprintf("%02d", i + 1) %></span>
                <%= link_to search_path(query: phrase),
                    class: "font-display text-xl text-ink hover:text-vermilion transition-colors italic",
                    data: { turbo: false } do %>
                  "<%= phrase %>"
                <% end %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% end %>
  <% end %>
</main>

<%= render "shared/footer" %>

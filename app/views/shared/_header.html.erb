<% subtitle ||= "A reader's index of Little Bear" %>
<header class="relative">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 lg:px-12 pt-8 sm:pt-10 pb-6">
    <div class="flex items-end justify-between gap-6">
      <%= link_to root_path, class: "group flex items-end gap-3 sm:gap-4" do %>
        <%# Logomark: a small ursine glyph drawn in vermilion, like a printer's bullet %>
        <span class="inline-flex items-center justify-center w-11 h-11 sm:w-12 sm:h-12 rounded-full bg-vermilion text-paper shadow-card transition-transform duration-300 group-hover:rotate-[-6deg]" aria-hidden="true">
          <svg viewBox="0 0 32 32" class="w-7 h-7" fill="none">
            <circle cx="10" cy="9" r="3" fill="currentColor"/>
            <circle cx="22" cy="9" r="3" fill="currentColor"/>
            <ellipse cx="16" cy="18" rx="9" ry="8" fill="currentColor"/>
            <circle cx="16" cy="20" r="2.5" fill="#1f1a14"/>
            <circle cx="13" cy="16" r="0.9" fill="#1f1a14"/>
            <circle cx="19" cy="16" r="0.9" fill="#1f1a14"/>
          </svg>
        </span>
        <span class="leading-none">
          <span class="block font-display text-3xl sm:text-4xl tracking-tight text-ink">
            FindThePhrase
          </span>
          <span class="block font-body-italic text-[13px] sm:text-sm text-ink-soft mt-1.5">
            <%= subtitle %>
          </span>
        </span>
      <% end %>

      <nav class="flex items-center gap-2 sm:gap-3 mb-1.5">
        <%= link_to favorite_segments_path, class: "group inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-full text-sm text-ink-soft hover:text-vermilion-deep transition-colors" do %>
          <svg class="w-4 h-4 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 20.5s-7.5-4.6-9.3-9.3C1.5 7.7 4 4.5 7.4 4.5c1.9 0 3.6 1 4.6 2.6 1-1.6 2.7-2.6 4.6-2.6 3.4 0 5.9 3.2 4.7 6.7C19.5 15.9 12 20.5 12 20.5z"/>
          </svg>
          <span class="font-display-text">Favorites</span>
        <% end %>
      </nav>
    </div>

    <%# Editorial rule: thin double line, like a chapter heading %>
    <div class="mt-6 sm:mt-8 border-t border-paper-edge"></div>
    <div class="mt-1 border-t border-paper-edge/60"></div>
  </div>
</header>
